{
  "expo": {
    "name": "Tally",
    "slug": "tally",
    "owner": "josh-approved",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAFAF7"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.joshapproved.tally"
    },
    "android": {
      "package": "com.joshapproved.tally",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAFAF7"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-localization",
      "expo-font",
      "expo-asset",
      "expo-iap",
      "./plugins/withGradleJvmArgs"
    ],
    "extra": {
      "eas": {
        "projectId": "3c07c9df-3dc5-4c14-a2e3-3bf195010081"
      }
    }
  }
}
